---
import type { SourceExcerpt as SourceExcerptType } from "../data/site";
import GlossaryText from "./GlossaryText.astro";

type Props = {
  item: SourceExcerptType;
};

const { item } = Astro.props;
const youngerPanelId = `${item.id}-younger-panel`;
const olderPanelId = `${item.id}-older-panel`;
const youngerTabId = `${item.id}-younger-tab`;
const olderTabId = `${item.id}-older-tab`;
---

<article class="k3m-source-excerpt" id={item.id}>
  <div class="k3m-source-excerpt__source">
    <div class="k3m-source-excerpt__source-inner">
      <p class="k3m-label">{item.label}</p>
      <h3 class="k3m-h3 mt-2 text-[length:1.35rem]">{item.title}</h3>
      <blockquote class="mt-5">
        {item.excerpt}
      </blockquote>
    </div>
  </div>

  <div class="k3m-source-excerpt__explain">
    <h4>Wyjaśnienie dla ucznia</h4>
    <p>
      <GlossaryText text={item.explanation} maxTooltips={3} />
    </p>

    {
      item.explanationLevels && (
        <div class="k3m-source-excerpt__levels" data-source-tabs>
          <div
            class="k3m-source-excerpt__tablist"
            role="tablist"
            aria-label="Poziom wyjaśnienia"
          >
            <button
              class="k3m-source-excerpt__tab"
              id={youngerTabId}
              type="button"
              role="tab"
              aria-selected="true"
              aria-controls={youngerPanelId}
              data-source-tab
            >
              Młodszy uczeń
            </button>
            <button
              class="k3m-source-excerpt__tab"
              id={olderTabId}
              type="button"
              role="tab"
              aria-selected="false"
              aria-controls={olderPanelId}
              tabindex="-1"
              data-source-tab
            >
              Starszy uczeń
            </button>
          </div>

          <section
            class="k3m-source-excerpt__level-panel"
            id={youngerPanelId}
            role="tabpanel"
            aria-labelledby={youngerTabId}
            data-source-panel
          >
            <p>
              <GlossaryText
                text={item.explanationLevels.younger}
                maxTooltips={2}
              />
            </p>
          </section>
          <section
            class="k3m-source-excerpt__level-panel"
            id={olderPanelId}
            role="tabpanel"
            aria-labelledby={olderTabId}
            data-source-panel
            hidden
          >
            <p>
              <GlossaryText
                text={item.explanationLevels.older}
                maxTooltips={2}
              />
            </p>
          </section>
        </div>
      )
    }

    <div class="mt-5">
      <h4>Trudne słowa</h4>
      <dl class="mt-3 grid gap-3">
        {
          item.difficultWords.map((word) => (
            <div>
              <dt>{word.term}</dt>
              <dd>
                <GlossaryText text={word.definition} maxTooltips={1} />
              </dd>
            </div>
          ))
        }
      </dl>
    </div>

    <div class="k3m-callout k3m-callout--exam mt-5">
      <h4>Pytanie do tekstu</h4>
      <p>
        <GlossaryText text={item.question} maxTooltips={2} />
      </p>
    </div>

    <div class="k3m-callout k3m-callout--remember mt-5">
      <h4>Co to zmieniło?</h4>
      <p>
        <GlossaryText text={item.effect} maxTooltips={2} />
      </p>
    </div>
  </div>
</article>

<script>
  const sourceTabGroups =
    document.querySelectorAll<HTMLElement>("[data-source-tabs]");

  sourceTabGroups.forEach((group) => {
    const tabs = Array.from(
      group.querySelectorAll<HTMLButtonElement>("[data-source-tab]"),
    );
    const panels = Array.from(
      group.querySelectorAll<HTMLElement>("[data-source-panel]"),
    );

    const activateTab = (nextTab: HTMLButtonElement, shouldFocus = true) => {
      tabs.forEach((tab) => {
        const isActive = tab === nextTab;
        const panelId = tab.getAttribute("aria-controls");
        const panel = panels.find((item) => item.id === panelId);

        tab.setAttribute("aria-selected", String(isActive));
        tab.tabIndex = isActive ? 0 : -1;

        if (panel) {
          panel.hidden = !isActive;
        }
      });

      if (shouldFocus) {
        nextTab.focus();
      }
    };

    tabs.forEach((tab, index) => {
      tab.addEventListener("click", () => activateTab(tab, false));
      tab.addEventListener("keydown", (event) => {
        const keyOffset =
          event.key === "ArrowRight" || event.key === "ArrowDown"
            ? 1
            : event.key === "ArrowLeft" || event.key === "ArrowUp"
              ? -1
              : 0;

        if (!keyOffset) return;

        event.preventDefault();
        const nextIndex = (index + keyOffset + tabs.length) % tabs.length;
        activateTab(tabs[nextIndex]);
      });
    });
  });
</script>
