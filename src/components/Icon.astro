  download: ["M12 3v11", "m8 10 4 4 4-4", "M5 21h14"],
  landmark: [
    "M3 9h18L12 4 3 9Z",
    "M5 9v9",
    "M9 9v9",
    "M15 9v9",
    "M19 9v9",
    "M4 18h16",
  ],
  map: ["M9 18 3 21V6l6-3 6 3 6-3v15l-6 3-6-3Z", "M9 3v15", "M15 6v15"],
  quiz: [
    "M12 21a9 9 0 1 0-9-9 9 9 0 0 0 9 9Z",
    "M9.75 9a2.25 2.25 0 1 1 3.9 1.53c-.72.72-1.65 1.07-1.65 2.22",
