---

<svg
  class:list={["k3m-icon", className]}
  aria-hidden="true"
  fill="none"
  focusable="false"
  viewBox="0 0 24 24"
  xmlns="http://www.w3.org/2000/svg"
>
  {
    iconPaths[name].map((path) => (
      <path
        d={path}
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="1.8"
      />
    ))
  }
</svg>
