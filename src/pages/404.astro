---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../utils/base";
---

<BaseLayout
  title="Nie znaleziono strony | Konstytucja 3 Maja dla uczniów"
  description="Strona 404 serwisu edukacyjnego o Konstytucji 3 Maja."
>
  <main class="k3m-container px-5 py-16 sm:px-8 lg:px-10">
    <section class="k3m-card max-w-3xl p-6 sm:p-8">
      <p class="k3m-label">404</p>
      <h1 class="k3m-h1 mt-4">Nie znaleziono tej strony</h1>
      <p class="k3m-lead mt-6">
        Ten adres nie prowadzi do żadnej podstrony serwisu. Możesz wrócić do
        najważniejszych materiałów albo od razu przejść do tekstu konstytucji z
        komentarzem.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="k3m-button k3m-button--primary" href={withBase("/")}
          >Wróć na start</a
        >
        <a
          class="k3m-button k3m-button--secondary"
          href={withBase("/tekst-konstytucji")}>Tekst konstytucji</a
        >
        <a
          class="k3m-button k3m-button--secondary"
          href={withBase("/materialy")}>Materiały</a
        >
      </div>
    </section>
  </main>
</BaseLayout>
